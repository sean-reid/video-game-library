# Copy to .env.development.local to override at dev time. The committed file
# documents the variables the app reads; the .local file (gitignored) is for
# per-developer values like a personal worker URL.

# Cloudflare Worker base. The web app calls /news, /article, /rawg/* against
# this origin. Defaults to the production worker that ships with the
# codeowner's repo (https://vgl-news.danrstaton.workers.dev). During local
# dev, set this to your own `vgl-news-dev.<your-subdomain>.workers.dev` so
# the /rawg/* proxy (with your RAWG_API_KEY secret) is reachable.
# VITE_WORKER_URL=https://vgl-news-dev.<your-subdomain>.workers.dev
