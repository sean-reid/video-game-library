{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client", "node"],
    "outDir": "dist",
    "rootDir": ".",
    "noEmit": true,
    "allowJs": true
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "vite.config.ts",
    "playwright.config.ts",
    "tailwind.config.ts"
  ]
}
