{
  "name": "@vgl/worker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --env dev",
    "deploy:dev": "wrangler deploy --env dev",
    "deploy:prod": "wrangler deploy --env prod",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "tail:dev": "wrangler tail --env dev",
    "tail:prod": "wrangler tail --env prod"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.27",
    "@cloudflare/workers-types": "^4.20251211.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "wrangler": "^3.99.0"
  }
}
